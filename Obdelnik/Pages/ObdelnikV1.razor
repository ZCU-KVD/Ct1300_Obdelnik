@page "/obdelnik1"

<PageTitle>Obdelník v1</PageTitle>

<h2>Obdelník v1 - tlačítko</h2>

<div class="mb-3 mt-3">
    <label for="stranaA" class="form-label">Zadej stranu A:</label>
    <input type="number" class="form-control" id="stranaA" @bind-value="obdelnik.StranaA" placeholder="Zadej stranu A">
</div>

<div class="mb-3 mt-3">
    <label for="stranaB" class="form-label">Zadej stranu B:</label>
    <input type="number" class="form-control" id="stranaB" @bind-value="obdelnik.StranaB" placeholder="Zadej stranu B">
</div>

<button type="button" class="btn btn-success" @onclick="obdelnik.SpocitejVse">Výpočet</button>

<div>
    <h3>Výsledek:</h3>
    <p><strong>Obvod:</strong>@($" {obdelnik.Obvod:N0}")   </p>
    <p><strong>Obsah:</strong>@($" {obdelnik.Obsah:N0}") </p>
    <p><strong>Uhlopříčka:</strong>@($" {obdelnik.Uhlopricka:N2}") </p>
</div>

@code {
    private Models.Obdelnik1 obdelnik = new Models.Obdelnik1();
}
