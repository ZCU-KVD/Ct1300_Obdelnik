@page "/obdelnik4"

<PageTitle>Obdelník v4</PageTitle>

<h2>Obdelník v4 - Formulář</h2>

<div class="card">
    <div class="card-header">Zadání</div>
    <div class="card-body">
        <EditForm Model="obdelnikForm" OnValidSubmit="Vypocitej">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <div class="mb-3 mt-3">
                <label for="stranaA" class="form-label">Strana A:</label>
                <input type="number" class="form-control" @bind-value="obdelnikForm.StranaA" id="stranaA" placeholder="Vložte stranu A" >
                <ValidationMessage For="@(() => obdelnikForm.StranaA)" />
            </div>

            <div class="mb-3 mt-3">
                <label for="stranaB" class="form-label">Strana B:</label>
                <InputNumber class="form-control" @bind-Value="obdelnikForm.StranaB" id="stranaB"  placeholder="Vložte stranu B" />
                <ValidationMessage For="@(() => obdelnikForm.StranaB)" />
            </div>

            <button type="submit" class="btn btn-success">Výpočet</button>
        </EditForm>
    </div>
</div>

@if (obdelnik != null)
{
    <div class="mt-3">
        <h3>Výsledek:</h3>
        <p><strong>Obvod:</strong>@($" {obdelnik.Obvod:N0}")   </p>
        <p><strong>Obsah:</strong>@($" {obdelnik.Obsah:N0}") </p>
        <p><strong>Uhlopříčka:</strong>@($" {obdelnik.Uhlopricka:N2}") </p>
    </div>
}


@code {
    private readonly Models.ObdelnikForm obdelnikForm = new Models.ObdelnikForm();
    private Models.Obdelnik2? obdelnik;

    private void Vypocitej()
    {
        // obdelnik = new Models.Obdelnik2
        // {
        //     StranaA = obdelnikForm.StranaA,
        //     StranaB = obdelnikForm.StranaB
        // };

        obdelnik = new Models.Obdelnik2(obdelnikForm.StranaA, obdelnikForm.StranaB);
    }
}
